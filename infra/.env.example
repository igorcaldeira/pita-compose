# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored (holds secrets). This template is committed for reference.

# ── General ──────────────────────────────────────────
TZ=America/Sao_Paulo

# ── WireGuard (WG-Easy) ─────────────────────────────
# WG_HOST: endpoint clients connect to. A LAN IP only works on home WiFi; for
# remote (5G) access use a public IP / DDNS hostname and forward UDP 51820.
# This MUST be the server's reachable IP on the WiFi your phone is on.
WG_HOST=10.0.0.100
# Generate with:  docker run --rm ghcr.io/wg-easy/wg-easy wgpw 'yourpassword'
# Note: in this file every literal $ must be doubled ($$) for docker compose.
WG_PASSWORD_HASH=$$2a$$12$$REPLACE_WITH_YOUR_BCRYPT_HASH
WG_DEFAULT_DNS=10.10.0.2
WG_PORT=51820
WG_UI_PORT=51821
# Split tunnel (lab subnet only). Add ,192.168.10.0/24 later for full LAN access.
WG_ALLOWED_IPS=10.10.0.0/24

# ── Pi-hole ──────────────────────────────────────────
PIHOLE_PASSWORD=changeme
PIHOLE_UI_PORT=8080

# ── Code Server ──────────────────────────────────────
CODESERVER_PASSWORD=changeme

# ── Portainer ────────────────────────────────────────
PORTAINER_ADMIN_PASSWORD=changeme

# ── FileBrowser ─────────────────────────────────────
FILEBROWSER_PASSWORD=changeme

# ── RustDesk (remote desktop) ───────────────────────
# Permanent password set on THIS host by infra/scripts/setup-rustdesk-client.sh.
# Leave as changeme to be prompted instead of storing it in a file.
RUSTDESK_PASSWORD=changeme
